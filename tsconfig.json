{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "outDir": "out",
        "lib": [
            "es6",
            "dom"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "skipLibCheck": true,
        "typeRoots": ["./node_modules/@types"]
    },
    "include": [
        "src/*.ts",
        "./node_modules/vscode/vscode.d.ts",
        "./node_modules/vscode/lib/*"
    ],
    "exclude": [
        "node_modules"
    ]
}